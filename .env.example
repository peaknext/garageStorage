# ===========================================
# SKH Storage Service - Environment Variables Example
# Copy this file to .env and fill in your values
# ===========================================

# ===========================================
# PostgreSQL Configuration (Docker container on port 9006)
# ===========================================
DATABASE_URL=postgresql://postgres:your_password@localhost:9006/garageStorage
DB_PASSWORD=your_postgres_password

# ===========================================
# Redis Configuration
# ===========================================
REDIS_PASSWORD=your_redis_password

# ===========================================
# S3-Compatible Storage Credentials (MinIO)
# (Generate via MinIO Console or mc admin user svcacct add)
# ===========================================
S3_ACCESS_KEY=YOUR_MINIO_ACCESS_KEY
S3_SECRET_KEY=your_minio_secret_key

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your_jwt_secret_key_at_least_32_characters
JWT_EXPIRES_IN=7d

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=development
API_PORT=9001
ADMIN_UI_PORT=9002

# ===========================================
# Storage Defaults
# ===========================================
DEFAULT_BUCKET_QUOTA_GB=10
MAX_FILE_SIZE_MB=100
PRESIGNED_URL_EXPIRES_SECONDS=3600
