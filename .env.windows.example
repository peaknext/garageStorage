# ===========================================
# SKH Storage Service - Windows Native Deployment
# Copy this file to .env and fill in your values
# ===========================================

# ===========================================
# PostgreSQL (Windows Service, port 5432)
# ===========================================
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/garageStorage
DB_PASSWORD=YOUR_PASSWORD

# ===========================================
# Redis / Memurai (Windows Service, port 6379)
# ===========================================
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ===========================================
# S3-Compatible Storage (MinIO on Windows)
# Generate access keys via MinIO Console or:
#   mc admin user svcacct add local minioadmin
# ===========================================
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://YOUR_SERVER_IP:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=YOUR_MINIO_ACCESS_KEY
S3_SECRET_KEY=YOUR_MINIO_SECRET_KEY

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your_jwt_secret_key_at_least_32_characters
JWT_EXPIRES_IN=24h

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=production
PORT=4000
API_BASE_URL=https://YOUR_DOMAIN
ADMIN_UI_URL=https://YOUR_DOMAIN

# ===========================================
# Storage Defaults
# ===========================================
DEFAULT_BUCKET_QUOTA_GB=10
MAX_FILE_SIZE_MB=100
PRESIGNED_URL_EXPIRES_SECONDS=3600

# ===========================================
# Email (Optional - for alert notifications)
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@yourdomain.com
