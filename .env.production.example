# ===========================================
# SKH Storage Service - PRODUCTION Environment
# ===========================================
# IMPORTANT: Generate secrets using: ./scripts/generate-secrets.sh --env-file .env.production
# NEVER commit .env.production to git!
# ===========================================

# ===========================================
# Server Configuration
# ===========================================
# Your domain name (used for nginx, CORS, share URLs)
SERVER_DOMAIN=storage.yourdomain.com

# Server IP (fallback if no domain, used for GARAGE_PUBLIC_ENDPOINT)
SERVER_IP=YOUR_SERVER_IP

# Enable SSL/HTTPS (true = port 443, false = port 80 only)
ENABLE_SSL=true

# ===========================================
# Docker Image (สำหรับ deploy ผ่าน Docker Hub)
# ===========================================
# Docker Hub username ตามด้วย / (trailing slash)
# เช่น peaknext/ → image จะเป็น peaknext/skh-storage-api:latest
IMAGE_REGISTRY=peaknext/

# Image tag (ปกติใช้ latest หรือ version เช่น v1.0.0)
IMAGE_TAG=latest

# ===========================================
# PostgreSQL Database
# ===========================================
# Generate: openssl rand -base64 24 | tr -d '/+='
DB_PASSWORD=CHANGE_ME
POSTGRES_USER=postgres
POSTGRES_DB=garageStorage

# ===========================================
# Redis Cache
# ===========================================
# Generate: openssl rand -base64 24 | tr -d '/+='
REDIS_PASSWORD=CHANGE_ME

# ===========================================
# JWT Authentication
# ===========================================
# Generate: openssl rand -base64 48 | tr -d '/+='
JWT_SECRET=CHANGE_ME
# Production: shorter expiry than development (24h vs 7d)
JWT_EXPIRES_IN=24h

# ===========================================
# Garage S3 Storage
# ===========================================
# API credentials (from setup-garage.sh output)
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=

# Garage admin token (must match garage/garage.prod.toml)
# Generate: openssl rand -base64 32
GARAGE_ADMIN_TOKEN=CHANGE_ME

# Garage RPC secret (must match garage/garage.prod.toml)
# Generate: openssl rand -hex 32
GARAGE_RPC_SECRET=CHANGE_ME

# Garage metrics token (must match garage/garage.prod.toml)
# Generate: openssl rand -base64 32
GARAGE_METRICS_TOKEN=CHANGE_ME

# ===========================================
# URLs
# ===========================================
# Public URL for the API (used in share links, webhooks)
# Example: https://storage.yourdomain.com or http://YOUR_SERVER_IP:9001
API_BASE_URL=https://storage.yourdomain.com

# Garage S3 public endpoint (for presigned URL browser access)
# Option A (direct): http://YOUR_SERVER_IP:9004
# Option B (nginx proxy): https://s3.storage.yourdomain.com
GARAGE_PUBLIC_ENDPOINT=http://YOUR_SERVER_IP:9004

# Frontend API URL (relative path works behind nginx)
NEXT_PUBLIC_API_URL=/api/v1

# Admin UI URL (for CORS)
ADMIN_UI_URL=https://storage.yourdomain.com

# ===========================================
# Email / SMTP (Optional - for quota alerts)
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ===========================================
# Storage Defaults
# ===========================================
DEFAULT_BUCKET_QUOTA_GB=10
MAX_FILE_SIZE_MB=100
PRESIGNED_URL_EXPIRES_SECONDS=3600

# ===========================================
# Monitoring (Optional)
# ===========================================
# AUDIT_RETENTION_DAYS=90
# ALERT_WARNING_THRESHOLD=75
# ALERT_CRITICAL_THRESHOLD=90
